<%- include('partials/header') %>
<h1><%= project.title %></h1>
<div class="project-details">
    <h2>Description</h2>
    <p>
        <%= project.description %>    
    </p>
    <h2>Date</h2>
    <p>
        <%= project.project_date.toLocaleDateString() %>
    </p>
    <h2>Location</h2>
    <p>
        <%= project.location %>
    </p>
    <h2>Partner Organization</h2>
    <p>
        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <h2>Categories</h2>
    <div class="category-tags">
        <% categories.forEach(category => { %>
            <a class="category-tag" href="/category/<%= category.category_id %>">
                <%= category.name %>
            </a>
        <% }) %>
</div>
<p>
    <a href="/projects">
        ← Back to Upcoming Projects
    </a>
</p>
<%- include('partials/footer') %>

